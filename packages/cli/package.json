{
  "name": "@pixelstream/cli",
  "version": "0.1.0",
  "description": "Build-time image resizer for @pixelstream/* (sharp-based)",
  "license": "MIT",
  "author": "Sage <cocacola158500@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/adhub1031/pixelstream.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "image",
    "resize",
    "cli",
    "sharp",
    "build-tool"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "pixelstream": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.7",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
