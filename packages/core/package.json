{
  "name": "@pixelstream/core",
  "version": "0.1.0",
  "description": "Framework-agnostic progressive image streaming",
  "license": "MIT",
  "author": "Sage <cocacola158500@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/adhub1031/pixelstream.git",
    "directory": "packages/core"
  },
  "keywords": [
    "image",
    "progressive",
    "lazy-load",
    "blur-up",
    "lqip",
    "cloudinary",
    "imgix",
    "imagekit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "jsdom": "^25.0.1",
    "@vitest/coverage-v8": "^2.1.4"
  }
}
