{
  "name": "@cn2kcorp/pixelstream-react",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "React component for progressive image streaming",
  "license": "MIT",
  "author": "Sage <cocacola158500@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/adhub1031/pixelstream.git",
    "directory": "packages/react"
  },
  "keywords": [
    "react",
    "image",
    "progressive",
    "lazy-load",
    "blur-up",
    "lqip"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cn2kcorp/pixelstream-core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@vitest/coverage-v8": "^2.1.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
